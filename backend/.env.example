PORT=8080
ENVIRONMENT=development

# Neon cloud Postgres — https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Upstash cloud Redis — https://upstash.com
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h

# CORS — set to your Vercel frontend URL in production
ALLOWED_ORIGINS=http://localhost:5173

# SMTP (optional — for email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@taskflow.app
SMTP_FROM_NAME=TaskFlow
